# Domain and IP Configuration
PUBLIC_DOMAIN=demo.example.com
PUBLIC_IP=203.0.113.1

# TLS Certificate Paths (relative to certs/ directory)
TLS_CERT=fullchain.pem
TLS_KEY=privkey.pem

# RTPEngine Port Range
RTP_PORT_MIN=10000
RTP_PORT_MAX=20000

# FreeSwitch Extension for Video Demo
VIDEO_EXTENSION=1000
