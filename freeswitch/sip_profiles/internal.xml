<include>
  <profile name="internal">
    <settings>
      <!-- Network Settings -->
      <param name="sip-ip" value="$${local_ip_v4}"/>
      <param name="rtp-ip" value="$${local_ip_v4}"/>
      <param name="sip-port" value="5060"/>
      
      <!-- NAT Settings for external connectivity -->
      <param name="ext-rtp-ip" value="66.90.142.106"/>
      <param name="ext-sip-ip" value="66.90.142.106"/>
      <param name="apply-nat-acl" value="rfc1918.auto"/>
      
      <!-- Codec Settings -->
      <param name="inbound-codec-negotiation" value="greedy"/>
      <param name="inbound-late-negotiation" value="true"/>
      
      <!-- Video Support -->
      <param name="rtp-video-max-bandwidth-in" value="3mb"/>
      <param name="rtp-video-max-bandwidth-out" value="3mb"/>
      
      <!-- Context for routing -->
      <param name="context" value="public"/>
      
      <!-- Accept calls from OpenSIPS -->
      <param name="accept-blind-auth" value="true"/>
      <param name="auth-calls" value="false"/>
      
      <!-- RTP timers -->
      <param name="rtp-timeout-sec" value="300"/>
      <param name="rtp-hold-timeout-sec" value="1800"/>
    </settings>
  </profile>
</include>
